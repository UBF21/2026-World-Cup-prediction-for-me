---
interface Props {
  value: string
  label: string
  accent?: 'pitch' | 'gold' | 'coral' | 'ink'
}
const { value, label, accent = 'ink' } = Astro.props
---
<div class="stat-card fade-up">
  <div class={`stat-value ${accent}`}>{value}</div>
  <div class="stat-label">{label}</div>
</div>

<style>
  .stat-card {
    padding: clamp(16px,3vw,24px) 18px;
    border-right: 1px solid var(--border);
    flex: 1;
  }
  .stat-card:last-child { border-right: none; }

  .stat-value {
    font-family: 'Anton', Impact, sans-serif;
    font-size: clamp(30px,5vw,50px);
    line-height: 1;
    color: var(--ink);
  }
  .stat-value.pitch { color: var(--pitch); }
  .stat-value.gold  { color: var(--gold);  }
  .stat-value.coral { color: var(--coral); }

  .stat-label {
    font: 600 10.5px/1.3 'Manrope';
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--muted);
    margin-top: 8px;
  }
</style>
