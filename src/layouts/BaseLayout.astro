---
interface Props {
  title?: string
  description?: string
}
const {
  title = 'Mundial 2026 · Predicción de los 104 partidos',
  description = 'Predicción completa del Mundial FIFA 2026: grupos, bracket, favoritos y metodología. España campeona según Opta. By Felipe Rafael Montenegro.',
} = Astro.props

const siteUrl = 'https://2026-world-cup-prediction-for-me.netlify.app'
const ogImage = `${siteUrl}/og.svg`
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={siteUrl} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"      content="es_ES" />
  <meta property="og:site_name"   content="Mundial 2026 · Predicción" />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <meta name="theme-color" content="#07111C" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Manrope:wght@400;500;600;700;800&family=Spline+Sans+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
